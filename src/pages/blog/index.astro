---
import { Picture } from "astro:assets";
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import Header from "../../components/Header.astro";
import { SITE_TITLE } from "../../consts";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} | Writing`}
			description="Essays and field notes about resilient infrastructure, failure handling, and staying useful when systems are under load."
		/>
	</head>
	<body>
		<Header />
		<main class="site-main">
			<section class="section page-hero">
				<div class="container">
					<h1>Writing archive</h1>
					<p>
						Essays and field notes about resilient infrastructure,
						failure handling, and staying useful when systems are
						under load.
					</p>
				</div>
			</section>

			<section class="section">
				<div class="container post-list-grid">
					{
						posts.map((post) => (
							<a
								href={`/blog/${post.id}/`}
								class="post-list-item surface-soft"
							>
								{post.data.heroImage && (
									<div class="post-list-media">
										<Picture
											width={720}
											height={400}
											src={post.data.heroImage}
											alt={post.data.title}
											formats={["avif", "webp"]}
											sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 720px"
											transition:name={`post-image-${post.id}`}
										/>
									</div>
								)}
								<div class="post-list-content">
									<p class="post-list-meta">
										<FormattedDate
											date={post.data.pubDate}
										/>
									</p>
									<h2>{post.data.title}</h2>
									<p>{post.data.description}</p>
								</div>
							</a>
						))
					}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
