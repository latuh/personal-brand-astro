---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { PROJECTS, SITE_TITLE } from "../consts";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`Work — ${SITE_TITLE}`}
			description="Infrastructure, control planes, pipelines. The systems you're not supposed to notice."
		/>
	</head>
	<body>
		<a href="#main" class="sr-only skip-link">Skip to content</a>
		<Header />
		<main id="main" class="site-main">
			{/* Hero */}
			<section class="section section-first">
				<div class="container">
					<span class="eyebrow anim-fade-up" style="--delay: 0.05s">
						<span class="num">§ 00</span>Work · Madrid, {year}
					</span>
					<h1 class="display-mega" style="margin-top: 32px; max-width: 14ch;">
						<span class="reveal-line">
							<span class="reveal-line-inner" style="--line: 0; --delay: 0.1s">Work that</span>
						</span>
						<span class="reveal-line">
							<span class="reveal-line-inner" style="--line: 1; --delay: 0.1s"><em>holds</em><span class="accent accent-pulse">.</span></span>
						</span>
					</h1>
					<div class="hero-grid anim-fade-up" style="--delay: 0.5s">
						<div class="hero-grid-serif">
							Platforms, pipelines, control planes — the parts of a
							stack that only show up when they break.
						</div>
						<div class="hero-grid-right">
							<p class="lead">
								A handful of things I've built and run. Some still
								do. Some were meant to be boring, and stayed that
								way.
							</p>
						</div>
					</div>
				</div>
			</section>

			{/* Work entries */}
			<section class="section">
				<div class="container">
					<div class="section-header reveal">
						<span class="eyebrow"><span class="num">§ 01</span>Selected work</span>
						<span class="section-all-link is-static">
							{PROJECTS.length} {PROJECTS.length === 1 ? "entry" : "entries"}
						</span>
					</div>
					<div class="proj-list">
						{PROJECTS.map((project, i) => (
							<article
								class="proj-item reveal"
								style={`--reveal-delay: ${0.05 + i * 0.08}s`}
							>
								<span class="proj-item-idx">
									{String(i + 1).padStart(2, "0")} ―
								</span>
								<div class="proj-item-body">
									<h2 class="proj-item-title">{project.title}</h2>
									<div class="proj-item-role">{project.role}</div>
									<p class="proj-item-desc">
										{project.longDescription}
									</p>
									<div class="proj-item-stack">
										{project.techStack.map((tech, idx) => (
											<>
												{idx > 0 && <span class="sep">·</span>}
												<span>{tech.toLowerCase()}</span>
											</>
										))}
									</div>
									{(project.url || project.github) && (
										<div class="proj-item-links">
											{project.url && (
												<a
													href={project.url}
													class="proj-item-link"
													target="_blank"
													rel="noreferrer"
												>
													View →
												</a>
											)}
											{project.github && (
												<a
													href={project.github}
													class="proj-item-link"
													target="_blank"
													rel="noreferrer"
												>
													Source →
												</a>
											)}
										</div>
									)}
								</div>
								<div class="proj-item-meta">
									<span class="proj-item-status">
										{project.url ? "Live" : "Running"}
									</span>
								</div>
							</article>
						))}
					</div>
				</div>
			</section>

			{/* Contact teaser */}
			<section class="section">
				<div class="container reveal" style="text-align: center">
					<span class="eyebrow"><span class="num">§ 02</span>Contact</span>
					<a href="mailto:hello@aaronmompie.com" class="contact-huge">
						hello@aaronmompie.com<span class="caret" aria-hidden="true"></span>
					</a>
				</div>
			</section>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
					},
					{ threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
				);
				document
					.querySelectorAll(".reveal")
					.forEach((el) => observer.observe(el));
			})();
		</script>
	</body>
</html>

<style>
	.section-all-link.is-static {
		pointer-events: none;
		color: var(--ink-4);
	}
	.section-all-link.is-static:hover {
		color: var(--ink-4);
		transform: none;
	}
	.section-all-link.is-static::after {
		display: none;
	}

	.proj-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--paper-3);
	}

	.proj-item {
		display: grid;
		grid-template-columns: 80px 1fr 120px;
		gap: 40px;
		padding: 72px 16px;
		border-bottom: 1px solid var(--paper-3);
		align-items: start;
		transition: background var(--dur-base) var(--ease-standard);
	}

	.proj-item:hover {
		background: var(--paper-2);
	}

	.proj-item-idx {
		font-family: var(--font-condensed);
		font-weight: 500;
		font-size: 13px;
		font-stretch: 75%;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-4);
		padding-top: 14px;
		transition: color var(--dur-base) var(--ease-standard);
	}

	.proj-item:hover .proj-item-idx {
		color: var(--accent);
	}

	.proj-item-body {
		min-width: 0;
	}

	.proj-item-title {
		font-family: var(--font-display);
		font-weight: 900;
		font-size: clamp(28px, 3.2vw, 44px);
		line-height: 1.02;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0;
		transition: color var(--dur-base) var(--ease-standard);
	}

	.proj-item:hover .proj-item-title {
		color: var(--accent);
	}

	.proj-item-role {
		font-family: var(--font-serif);
		font-weight: 400;
		font-style: italic;
		font-size: 20px;
		line-height: 1.3;
		color: var(--ink-3);
		margin-top: 14px;
	}

	.proj-item-desc {
		font-family: var(--font-sans);
		font-size: 16px;
		line-height: 1.65;
		color: var(--ink-2);
		margin: 32px 0 0;
		max-width: 60ch;
	}

	.proj-item-stack {
		margin-top: 32px;
		font-family: var(--font-condensed);
		font-size: 12px;
		font-stretch: 75%;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-4);
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		align-items: baseline;
	}

	.proj-item-stack .sep {
		color: var(--ink-5);
	}

	.proj-item-links {
		margin-top: 36px;
		display: flex;
		gap: 28px;
	}

	.proj-item-link {
		font-family: var(--font-sans);
		font-size: 14px;
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px solid var(--ink-4);
		padding-bottom: 2px;
		transition:
			color var(--dur-base) var(--ease-standard),
			border-color var(--dur-base) var(--ease-standard);
	}

	.proj-item-link:hover {
		color: var(--accent);
		border-bottom-color: var(--accent);
	}

	.proj-item-meta {
		text-align: right;
		padding-top: 14px;
	}

	.proj-item-status {
		font-family: var(--font-condensed);
		font-weight: 500;
		font-size: 12px;
		font-stretch: 75%;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--ink-4);
	}

	@media (max-width: 760px) {
		.proj-item {
			grid-template-columns: 48px 1fr;
			gap: 20px;
			padding: 56px 12px;
		}

		.proj-item-meta {
			display: none;
		}

		.proj-item-title {
			font-size: clamp(26px, 7vw, 34px);
		}

		.proj-item-role {
			font-size: 17px;
		}

		.proj-item-idx {
			padding-top: 10px;
		}
	}
</style>
