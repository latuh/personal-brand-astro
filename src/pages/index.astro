---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	SITE_LINKEDIN_URL,
	SITE_RESUME_URL,
	SITE_X_URL,
} from '../consts';
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="antialiased">
		<Header />
		<main class="mx-auto max-w-5xl px-4">
			<section
				id="hero"
				class="relative grid min-h-[calc(100vh-3.5rem)] items-center gap-16 pb-24 pt-12 md:grid-cols-2 md:py-16 xl:gap-24"
			>
				<!-- Portrait -->
				<div class="flex justify-center md:justify-start">
					<Image
						src={AboutHeroImage}
						alt="Portrait of Aaron Mompié"
						class="w-full max-w-[18rem] aspect-[3/4] rounded-2xl object-cover ring-1 ring-white/[0.07] md:max-w-[22rem]"
						loading="eager"
						widths={[480, 800]}
						sizes="(max-width: 768px) 18rem, 22rem"
					/>
				</div>

				<!-- Copy -->
				<div class="space-y-7">
					<span class="hero-pill inline-flex items-center rounded-full border border-white/10 bg-white/[0.05] px-3.5 py-1 text-[0.65rem] uppercase tracking-[0.25em] text-neutral-300">
						Infra Engineer · Writer
					</span>

					<h1 class="gradient-text font-display text-4xl leading-[1.08] sm:text-5xl md:text-[3.5rem]">
						Aaron Mompié
					</h1>

					<p class="max-w-sm text-[0.95rem] leading-[1.75] text-neutral-400">
						I build systems and think in public. Engineering, infrastructure, and the examined life —
						written for people who believe precision and depth are not opposites.
					</p>

					<div class="flex flex-wrap items-center gap-3 pt-1">
						<a
							href={SITE_RESUME_URL}
							class="btn-primary inline-flex items-center rounded-full bg-white px-5 py-2 text-sm font-medium text-[#09090e] transition hover:bg-neutral-200"
						>
							View résumé
						</a>
						<a
							href={SITE_LINKEDIN_URL}
							class="btn-ghost inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-neutral-400 transition hover:border-white/20 hover:text-white"
							rel="noreferrer"
							target="_blank"
							aria-label="LinkedIn"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
							</svg>
						</a>
						<a
							href={SITE_X_URL}
							class="btn-ghost inline-flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-neutral-400 transition hover:border-white/20 hover:text-white"
							rel="noreferrer"
							target="_blank"
							aria-label="X (Twitter)"
						>
							<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
								<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
							</svg>
						</a>
					</div>
				</div>

				<div class="absolute inset-x-0 bottom-6 flex justify-center">
					<a
						href="#featured"
						class="scroll-indicator inline-flex flex-col items-center text-[0.6rem] uppercase tracking-[0.3em] text-neutral-700"
					>
						<span class="mb-3">Scroll</span>
						<span class="h-10 w-px rounded-full bg-white/10"></span>
					</a>
				</div>
			</section>

			{posts.length > 0 && (
				<section id="featured" class="mx-auto max-w-5xl min-h-screen border-t border-white/[0.06] flex flex-col justify-center py-16">
					<div class="will-fade flex items-baseline justify-between gap-4">
						<h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.3em] text-neutral-500">
							Featured writing
						</h2>
						<a href="/blog" class="text-xs font-medium text-neutral-500 transition hover:text-neutral-200">
							View all →
						</a>
					</div>

					<div class="mt-6 grid gap-4 md:grid-cols-3">
						{posts.map((post, i) => (
							<a
								href={`/blog/${post.id}/`}
								class="will-fade card-linear group flex flex-col overflow-hidden rounded-2xl p-5"
								style={`animation-delay: ${(i + 1) * 0.12}s`}
							>
								{post.data.heroImage && (
									<Image
										width={480}
										height={260}
										src={post.data.heroImage}
										alt={post.data.title}
										class="mb-4 rounded-xl object-cover opacity-90 transition group-hover:opacity-100"
										loading="lazy"
									/>
								)}
								<h3 class="text-sm font-semibold text-neutral-100 transition group-hover:text-white">
									{post.data.title}
								</h3>
								<p class="mt-2 line-clamp-3 text-xs leading-relaxed text-neutral-400">
									{post.data.description}
								</p>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		{posts.length > 0 && (
			<nav
				aria-label="Page sections"
				class="fixed right-5 top-1/2 z-50 -translate-y-1/2 flex flex-col gap-2"
			>
				<button
					data-section-pill
					class="w-[3px] rounded-full bg-white transition-all duration-300 cursor-pointer"
					style="height: 2rem; opacity: 0.8;"
					aria-label="Go to introduction"
				></button>
				<button
					data-section-pill
					class="w-[3px] rounded-full bg-white transition-all duration-300 cursor-pointer"
					style="height: 0.875rem; opacity: 0.2;"
					aria-label="Go to featured writing"
				></button>
			</nav>
		)}
		<Footer />
		<script is:inline>
			if (typeof window !== 'undefined') {
				const hero = document.getElementById('hero');
				const featured = document.getElementById('featured');
				const pills = document.querySelectorAll('[data-section-pill]');
				let isJumping = false;

				// --- Fade-in for featured content ---
				if (featured) {
					const fadeEls = featured.querySelectorAll('.will-fade');
					const fadeObserver = new IntersectionObserver(
						(entries) => {
							if (entries[0].isIntersecting) {
								fadeEls.forEach((el) => el.classList.add('fade-up'));
								fadeObserver.disconnect();
							}
						},
						{ threshold: 0.15 },
					);
					fadeObserver.observe(featured);
				}

				// --- Pill active state ---
				const setActivePill = (index) => {
					pills.forEach((pill, i) => {
						const active = i === index;
						pill.style.height = active ? '2rem' : '0.875rem';
						pill.style.opacity = active ? '0.8' : '0.2';
					});
				};

				const pillObserver = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) setActivePill(entry.target.id === 'hero' ? 0 : 1);
						});
					},
					{ threshold: 0.4 },
				);
				if (hero) pillObserver.observe(hero);
				if (featured) pillObserver.observe(featured);

				// --- Pill click navigation ---
				pills.forEach((pill, i) => {
					pill.addEventListener('click', () => {
						const target = i === 0 ? hero : featured;
						target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					});
				});

				// --- Jump scroll ---
				if (hero && featured) {
					window.addEventListener(
						'wheel',
						(e) => {
							if (isJumping) {
								e.preventDefault();
								return;
							}

							const scrollY = window.scrollY;
							const featuredTop = featured.offsetTop;

							if (e.deltaY > 10 && scrollY < featuredTop - 50) {
								// In hero zone — snap down to featured
								e.preventDefault();
								isJumping = true;
								featured.scrollIntoView({ behavior: 'smooth', block: 'start' });
								setTimeout(() => { isJumping = false; }, 900);
							} else if (e.deltaY < -10 && scrollY >= featuredTop - 80 && scrollY <= featuredTop + 100) {
								// At top of featured — snap back up to hero
								e.preventDefault();
								isJumping = true;
								window.scrollTo({ top: 0, behavior: 'smooth' });
								setTimeout(() => { isJumping = false; }, 900);
							}
						},
						{ passive: false },
					);
				}
			}
		</script>
	</body>
</html>
