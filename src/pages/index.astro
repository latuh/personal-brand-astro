---
import { Image, Picture } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import {
	SITE_DESCRIPTION,
	SITE_TITLE,
	SITE_LINKEDIN_URL,
	SITE_RESUME_URL,
	SITE_X_URL,
	SITE_INSTAGRAM_URL,
	CAROUSEL_ENABLED,
} from '../consts';

import carouselMe from '../assets/me.jpg';
import carouselPve from '../assets/pve.png';
import carouselPortainer from '../assets/portainer.png';

const carouselImages = [
	{ src: carouselMe, alt: 'Aaron Mompié', position: 'center 13%' },
	{ src: carouselPve, alt: 'Proxmox VE dashboard', position: 'center 10%' },
	{ src: carouselPortainer, alt: 'Portainer container management', position: 'center' },
];

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>
<body>
	<a href="#main" class="sr-only skip-link">Skip to content</a>
	<Header />
	<main id="main" class="site-main home-snap">

		<section id="sec-hero" class="snap-section hero-snap">
			<div class="container hero-container">
				<div class="hero-top">
					<div class="hero-primary">
						<div class="hero-kicker-row">
							<span class="kicker-pill anim-fade-up" style="--delay: 0.12s">Engineer</span>
							<span class="kicker-pill anim-fade-up" style="--delay: 0.2s">Writer</span>
							<span class="kicker-pill anim-fade-up" style="--delay: 0.28s">Thinker</span>
						</div>
						<h1 class="hero-title anim-fade-up" style="--delay: 0.3s">Building systems that hold, for days that don't.</h1>
						<p class="hero-body anim-fade-up" style="--delay: 0.42s">
							The same principles that keep infrastructure standing keep a person up too.
						</p>
						<div class="hero-actions anim-fade-up" style="--delay: 0.52s">
							<a href={SITE_RESUME_URL} class="btn btn-ghost">View CV</a>
							<div class="hero-socials">
								<a href={SITE_LINKEDIN_URL} rel="noreferrer" target="_blank" class="social-link" aria-label="LinkedIn">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
								</a>
								<a href={SITE_X_URL} rel="noreferrer" target="_blank" class="social-link" aria-label="X / Twitter">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								</a>
								<a href={SITE_INSTAGRAM_URL} rel="noreferrer" target="_blank" class="social-link" aria-label="Instagram">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
								</a>
							</div>
						</div>
					</div>
				{CAROUSEL_ENABLED ? (
					<aside class="hero-carousel anim-slide-right" style="--delay: 0.35s" aria-label="Photo carousel">
						<div class="carousel-track" id="carousel-track">
							{carouselImages.map((img, i) => (
								<div class={`carousel-slide ${i === 0 ? 'is-active' : ''}`}>
									<Image
										src={img.src}
										alt={img.alt}
										width={1200}
										quality={85}
										format="webp"
										style={`object-position: ${img.position}`}
										loading={i === 0 ? 'eager' : 'lazy'}
										fetchpriority={i === 0 ? 'high' : 'low'}
									/>
								</div>
							))}
						</div>
						<div class="carousel-dots" id="carousel-dots">
							{carouselImages.map((_img, i) => (
								<button
									class={`carousel-dot ${i === 0 ? 'is-active' : ''}`}
									aria-label={`Go to slide ${i + 1}`}
									data-index={i}
								/>
							))}
						</div>
					</aside>
				) : (
					<aside class="hero-carousel anim-slide-right" style="--delay: 0.35s">
						<Image
							src={carouselMe}
							alt="Aaron Mompié"
							width={1200}
							quality={85}
							format="webp"
							style="object-position: center 13%"
							loading="eager"
							fetchpriority="high"
						/>
					</aside>
				)}
				</div>

				{posts.length > 0 && (
					<div class="featured-strip anim-fade-up" style="--delay: 0.6s">
						<div class="featured-strip-header">
							<span class="featured-label">Featured</span>
							<a href="/blog" class="featured-view-all">View all &rarr;</a>
						</div>
						<div class="featured-cards">
							{posts.map((post) => (
								<a href={`/blog/${post.id}/`} class="fcard">
									{post.data.heroImage && (
										<div class="fcard-thumb">
											<Picture
												width={400}
												height={533}
												src={post.data.heroImage}
												alt={post.data.title}
												formats={['avif', 'webp']}
												transition:name={`post-image-${post.id}`}
											/>
										</div>
									)}
									<div class="fcard-content">
										<div class="fcard-meta">
											<p class="fcard-date">
												{post.data.pubDate.toLocaleDateString('en-US', {
													month: 'short',
													day: 'numeric',
												})}
											</p>
											<h3 class="fcard-title">{post.data.title}</h3>
										</div>
										<svg class="fcard-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
									</div>
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</section>

		<section id="sec-about" class="snap-section">
			<div class="container about-section">
				<div class="about-header reveal">
					<p class="hero-kicker">About</p>
					<h2 class="section-heading">Building things.<br />Writing about the rest.</h2>
				</div>
				<div class="about-columns">
					<div class="about-main reveal" style="--reveal-delay: 0.1s">
						<p class="about-lead">
							I'm an engineer who writes. My work lives at the intersection of
							production systems and personal reflection &mdash; building infrastructure
							that holds up, and writing essays about the people and ideas that
							shape how we think.
						</p>
						<ul class="about-points">
							<li>Engineering reliable platforms with clear observability and recovery paths.</li>
							<li>Writing long-form essays on systems, people, and the craft of paying attention.</li>
							<li>Exploring how we build, connect, and make sense of things under pressure.</li>
						</ul>
					</div>
					<div class="about-aside reveal" style="--reveal-delay: 0.2s">
						<dl class="about-facts">
							<div>
								<dt>Role</dt>
								<dd>Infrastructure engineer</dd>
							</div>
							<div>
								<dt>Writing</dt>
								<dd>Essays on systems, people, and ideas</dd>
							</div>
							<div>
								<dt>Approach</dt>
								<dd>Calm systems, sharp focus, human-first thinking</dd>
							</div>
						</dl>
						<div class="about-links-row">
							<a href={SITE_LINKEDIN_URL} rel="noreferrer" target="_blank">LinkedIn &#8599;</a>
							<a href={SITE_X_URL} rel="noreferrer" target="_blank">X / Twitter &#8599;</a>
							<a href="/about">More about me &#8594;</a>
						</div>
					</div>
				</div>
			</div>
		</section>

	</main>
	<Footer />

	<script is:inline>
		(function () {
			/* Scroll reveal */
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				},
				{ threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
			);
			document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

			/* Carousel */
			const track = document.getElementById('carousel-track');
			const dotsContainer = document.getElementById('carousel-dots');
			if (!track || !dotsContainer) return;

			const slides = track.querySelectorAll('.carousel-slide');
			const dots = dotsContainer.querySelectorAll('.carousel-dot');
			if (slides.length < 2) return;

			let current = 0;
			const total = slides.length;
			const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			function goTo(index) {
				slides[current].classList.remove('is-active');
				dots[current].classList.remove('is-active');
				current = (index + total) % total;
				slides[current].classList.add('is-active');
				dots[current].classList.add('is-active');
			}

			dots.forEach((dot) => {
				dot.addEventListener('click', () => {
					goTo(Number(dot.dataset.index));
				});
			});

			if (!prefersReduced) {
				var paused = false;
				var carousel = track.closest('.hero-carousel');
				if (carousel) {
					carousel.addEventListener('mouseenter', function () { paused = true; });
					carousel.addEventListener('mouseleave', function () { paused = false; });
					carousel.addEventListener('focusin', function () { paused = true; });
					carousel.addEventListener('focusout', function () { paused = false; });
				}
				var intervalId = setInterval(function () { if (!paused) goTo(current + 1); }, 4000);
				document.addEventListener('astro:before-preparation', function () {
					clearInterval(intervalId);
				}, { once: true });
			}
		})();
	</script>
</body>
</html>
