---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="sticky top-0 z-50 backdrop-blur-xl" style="background: var(--bg-nav); border-bottom: 1px solid var(--nav-border);">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-5">
		<a href="/" class="font-display text-xs font-semibold tracking-[0.22em] text-[var(--text)] uppercase">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			<HeaderLink href="/blog">Writing</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>

			<!-- Theme toggle -->
			<button
				id="theme-toggle"
				aria-label="Toggle light/dark mode"
				class="ml-2 inline-flex h-9 w-9 items-center justify-center rounded-full border transition"
				style="border-color: var(--nav-border); color: var(--text-muted);"
			>
				<!-- Sun (shown in dark mode) -->
				<svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-4 w-4" aria-hidden="true">
					<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
				</svg>
				<!-- Moon (shown in light mode) -->
				<svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-4 w-4 hidden" aria-hidden="true">
					<path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
				</svg>
			</button>
		</div>
	</nav>
</header>

<script is:inline>
	(function () {
		function applyTheme(theme) {
			document.documentElement.setAttribute('data-theme', theme);
			localStorage.setItem('theme', theme);
			var sun  = document.getElementById('icon-sun');
			var moon = document.getElementById('icon-moon');
			if (theme === 'light') {
				sun  && sun.classList.add('hidden');
				moon && moon.classList.remove('hidden');
			} else {
				sun  && sun.classList.remove('hidden');
				moon && moon.classList.add('hidden');
			}
		}

		// Sync icon on load
		applyTheme(document.documentElement.getAttribute('data-theme') || 'dark');

		document.getElementById('theme-toggle')?.addEventListener('click', function () {
			var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
			applyTheme(next);
		});
	})();
</script>
